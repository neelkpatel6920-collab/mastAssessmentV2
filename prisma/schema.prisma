generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  MASTER_ADMIN
  ZONE_ADMIN
  CENTER_ADMIN
}

model Zone {
  id        String      @id @default(cuid())
  name      String      @unique
  centers   Center[]
  admins    AdminUser[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Center {
  id        String         @id @default(cuid())
  name      String
  zoneId    String
  zone      Zone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  admins    AdminUser[]
  responses TestResponse[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([zoneId, name])
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole
  zoneId       String?
  centerId     String?
  zone         Zone?     @relation(fields: [zoneId], references: [id])
  center       Center?   @relation(fields: [centerId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model TestResponse {
  id              String   @id @default(cuid())
  participantName String
  age             Int
  zoneId          String
  centerId        String
  center          Center   @relation(fields: [centerId], references: [id])
  answers         Json
  scoreM          Int
  scoreA          Int
  scoreS          Int
  scoreT          Int
  primaryType     String
  secondaryType   String
  sequence        String
  submittedAt     DateTime @default(now())

  @@index([centerId])
  @@index([submittedAt])
  @@index([primaryType])
}
