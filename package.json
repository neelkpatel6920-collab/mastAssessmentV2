{
  "name": "mast-test-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @mast/participant --filter @mast/admin dev",
    "dev:participant": "pnpm --filter @mast/participant dev",
    "dev:admin": "pnpm --filter @mast/admin dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "test": "pnpm --filter @mast/core test",
    "admin:messages": "python scripts/generate_admin_messages.py",
    "firebase:seed": "tsx scripts/seed_firestore.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "postcss": "^8.4.39",
    "prisma": "^5.16.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "@react-pdf/renderer": "^3.4.4",
    "bcryptjs": "^2.4.3",
    "jose": "^5.6.3",
    "lucide-react": "^0.468.0",
    "next": "^14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "zod": "^3.23.8",
    "firebase-admin": "^14.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
